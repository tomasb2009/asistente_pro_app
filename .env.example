# Copia este archivo a ".env" en la raíz del proyecto y rellena la clave.
# No subas .env a repositorios públicos.
OPENAI_API_KEY=

# Opcional: clima (Open-Meteo). Por defecto: Córdoba, Argentina.
# OPEN_METEO_LAT=-31.4201
# OPEN_METEO_LON=-64.1888

# Opcional sidecar voz (wake/VAD local)
# 1) Ejecuta native/voice_sidecar/scripts/bootstrap.ps1 (o .sh) una vez.
# 2) Sin VOICE_SIDECAR_PYTHON, la app usa native/voice_sidecar/.venv si existe.
# No uses solo "python" aquí (PATH sin dependencias). Ruta al .exe de la venv o nada.
# VOICE_SIDECAR_PYTHON=C:\ruta\al\proyecto\native\voice_sidecar\.venv\Scripts\python.exe
# VOICE_SIDECAR_BIN=C:\\ruta\\voice_sidecar.exe
# VOICE_SIDECAR_VOSK_MODEL=C:\\ruta\\vosk-model-small-es-0.42
# VOICE_WAKE_PHRASE=ok asistente
# VOICE_ENABLE_RNNOISE=true
# VOICE_ENABLE_WEBRTC_VAD=true
# VOICE_COMMAND_SILENCE_MS=1400
# VOICE_MAX_COMMAND_MS=45000
